.testing <- TRUE
tst <- function(x, force=FALSE, ...) {
if(.testing|force) {
    cat("-->", deparse(substitute(x)),..., "\n")
     print(x)
     }
invisible(x)
}
coef <- 1:5
tst(coef)
.testing <- FALSE
tst(coef,TRUE,"Za poskus force=TRUE")
