#         points(3,e,col=3)
#         arrows(3,e,3,e+cF[3],col=3,length=0.08, lwd=lwda)
         }
         eind <- grind[ ,1,2]  #c(2,6,7)
                  tst(eind)
                  esF <- predicted(eind,coef)
         es <- esF-coef[,eind]
         lines(1:ndays,es,col=7,lwd=3)
         lines(1:ndays,esF,col=7,lwd=3)
         lines(1:ndays,es,col=8,type="b",lwd=1,lty=3)
#
         arrows(1:ndays,es,1:ndays,esF,col=1:ndays,length=0.08, lwd=lwda)
#

         ii <- ndays+1
         e <- cc[1]+cF[1]
#         points(1,e,col=ii,cex=2)
#         arrows(1,e,1,e+cf[ii],col=ii,length=0.08, lwd=lwda)
           es <- predicted(8,coef)-coef[,8]+c(0,coef[,c(9,10)])
           es <- predicted(2,coef)+coef[,5]+c(0,coef[,c(3,4)])
           lines(1:ndays,es,col=7,lwd=1,lty=4,type="b")
           es <- es+c(0,coef[,c(9,10)])
           lines(1:ndays,es,col=7+1,lwd=1,lty=4,type="b")
                      es <- es+c(0,coef[,c(6,7)])
