delta <- c(coef[,eind[1]],rep(0,length(eind)-1))
         lines(1:ndays,delta+es,col=2,type="b",lwd=1,lty=3)
#
         arrows(1:ndays+d,es,1:ndays+d,esF,col=cl+1:ndays,length=0.08, lwd=lwda)
       cfs <- 1:(ndays*ntreat)
       ltext <- paste(sprintf("% .1f",cf[cfs]),"|",names(cf)[cfs])
       legend("topleft",col=cfs,lwd=2,legend=ltext, bty="n",cex=0.75)
       } else {
#
### second level
#
if(FALSE){
         cF <- coef[,ind]
         abline(h=cc[1], col=8)
# expected for C
#         lines(1:ndays,cc[1]+cF[1]+c(0,cc[2:ndays]),col=8,type="b",lwd=1,lty=3)
#
         e <- cc[1]
         points(0.95,e,col=1)
         arrows(0.95,e,0.95,e+cF[1],col=1,length=0.08, lwd=lwda)
         for(ii in 2:ndays){
         e <- sum(cc[c(1,ii)])+cF[1]
#         points(ii-d,e,col=ii)
#         arrows(ii-d,e,ii-d,e+cF[ii],col=ii,length=0.08, lwd=lwda)
