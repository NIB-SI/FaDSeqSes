           es <- esF-coef[c(8,11,12)]
      #  lines(1:ndays,cf[1]+cf[ii]+c(0,cf[2:ndays]),col=2,lwd=1,lty=2)
      lines(1:ndays,es,col=2,lwd=1,lty=3,type="b")
#      lines(1:ndays,esF,col=7,lwd=1,lty=4,type="b")

#      eC <- predicted(c(5,9,10),coef)
