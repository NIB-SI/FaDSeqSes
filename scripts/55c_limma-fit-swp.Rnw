fit3[testvar,]$coefficients
@

Combine design2 and design3:
Replace interceps with means in coefficients and standard deviations

<<>>=
fit4 <- fit2
fit4$coefficients[,1] <- fit3$coefficients[,1]
fit4$coefficients[,3] <- fit3$coefficients[,2]
fit4$stdev.unscaled[,1] <- fit3$stdev.unscaled[,1]
fit4$stdev.unscaled[,3] <- fit3$stdev.unscaled[,2]
dimnames(fit4$coefficients)[[2]] <- c("mc","c1","mf","f1.c1")
fit4[testvar,]$coefficients
fit2[testvar,]$coefficients
fit3[testvar,]$coefficients
